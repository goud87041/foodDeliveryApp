# Server
PORT=5000
# Uploaded images are stored in ./uploads and served at GET /uploads/<filename>
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/fooddelivery

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# CORS — comma-separated origins (Vite defaults)
CLIENT_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Email (optional — forgot password falls back to console log if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@fooddelivery.local

# Razorpay (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Google Maps (optional — frontend key for maps)
VITE_GOOGLE_MAPS_API_KEY=
