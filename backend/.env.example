# Server
PORT=5000
NODE_ENV=development
# Uploaded images: ./uploads served at GET /uploads/<filename>

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/fooddelivery

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# CORS — comma-separated exact frontend URLs (local + deployed)
# Example production:
# CLIENT_ORIGINS=https://my-user.vercel.app,https://my-admin.vercel.app,https://my-delivery.vercel.app
CLIENT_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Optional regex patterns for preview deploys (comma-separated, no slashes around pattern)
# CLIENT_ORIGIN_PATTERNS=^https://.*\.vercel\.app$,^https://.*\.onrender\.com$

# Allow localhost / 127.0.0.1 on any port (default true). Set false to only use CLIENT_ORIGINS.
CORS_ALLOW_LOCALHOST=true

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@fooddelivery.local

# Razorpay (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
